  "generalRules": {
    "dynamicBeforeStatic": "Perform dynamic stretching before resistance training. Reserve prolonged static stretching for after training.",
    "movementSpecific": "Warm-up movements should resemble the exercises performed during the workout.",
    "increaseTemperature": "Always elevate heart rate before heavy lifting.",
    "neverSkipWarmup": "Every workout should begin with a structured warm-up.",
    "individualize": "Adjust warm-up duration based on training intensity, experience and joint restrictions."
  },

  "beginnerGuidelines": [
    "Spend additional time learning movement patterns.",
    "Use lighter warm-up loads than experienced lifters.",
    "Do not rush through mobility drills.",
    "Prioritize movement quality over speed.",
    "Warm-up sets are practice, not working sets."
  ],

  "safetyGuidelines": [
    "Warm-up should never cause pain.",
    "Stop any drill that causes sharp discomfort.",
    "Increase range of motion gradually.",
    "Dynamic stretching should remain controlled.",
    "Do not perform maximal lifts without progressive warm-up sets.",
    "If a joint feels restricted, spend additional time mobilizing before loading."
  ],

